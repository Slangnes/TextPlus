{
  "name": "@textplus/author",
  "version": "0.0.1",
  "description": "TextPlus Author - Modern Raconteur authoring DSL",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
